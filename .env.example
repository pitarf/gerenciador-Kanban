# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Neon PostgreSQL connection string
DATABASE_URL="postgresql://neondb_owner:npg_xRcZ7ALl1YWd@ep-lingering-waterfall-am0zghi2.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT_SECRET: Secret for authentication
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY"

# INTERNAL_SYNC_TOKEN: Token for protected sync endpoints
INTERNAL_SYNC_TOKEN="YOUR_INTERNAL_SYNC_TOKEN"
